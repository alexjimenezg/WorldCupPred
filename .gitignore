# Secrets
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/
.pytest_cache/

# Data: keep folder structure (.gitkeep) but not large/raw artifacts.
# data/processed and models ARE committed (small, ~5 MB): they seed the
# Streamlit Cloud deployment, which has no persistent disk. A local
# recompute dirties them — push when you want the cloud seed updated.
data/raw/*
data/interim/*
!data/**/.gitkeep

# Reports figures are regenerable
reports/figures/*
!reports/figures/.gitkeep

# OS
.DS_Store
Thumbs.db
.notify_state.json
