# Copy to .env and fill in. All keys are OPTIONAL — the project runs fully on the
# free historical backbone (martj42 results + eloratings.net) without any of them.
# .env is git-ignored.

# The Odds API (free tier ~500 req/month): https://the-odds-api.com/  -> betting odds
ODDS_API_KEY=

# football-data.org (free tier): https://www.football-data.org/  -> 2026 fixtures & live scores
FOOTBALL_DATA_API_KEY=
